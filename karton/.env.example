# Kopiraj u .env i po potrebi izmeni. .env se ne commit-uje.

NODE_ENV=development

# --- Baza (poklapa se sa docker-compose.yml) ---
DATABASE_URL=postgres://karton:karton@localhost:5544/karton

# --- API ---
API_PORT=3000
# Bazni URL aplikacije — koristi se za QR kod naloga. NIKAD hardkodovan localhost u kodu.
APP_BASE_URL=http://localhost:5173
# Tajna za potpisivanje sesijskog kolačića (u produkciji: dugačka slučajna vrednost)
SESSION_SECRET=dev-only-promeni-me-u-produkciji-000000000000

# --- SMTP (lokalno: Mailpit iz docker-compose.yml) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SENDER_EMAIL=servis@localhost

# Backup (spec §4.14) — direktorijum za pg_dump fajlove; DB_CONTAINER je fallback kad pg_dump nije na PATH-u
BACKUP_DIR=./backups
DB_CONTAINER=karton-db
