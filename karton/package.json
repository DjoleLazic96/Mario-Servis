{
  "name": "karton",
  "version": "0.1.0",
  "private": true,
  "description": "Karton — vođenje auto servisa (modularni monolit)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:db": "docker compose up -d",
    "dev:db:down": "docker compose down",
    "migrate": "pnpm --filter @karton/api migrate",
    "seed": "pnpm --filter @karton/api seed",
    "dev:api": "pnpm --filter @karton/api dev",
    "dev:worker": "pnpm --filter @karton/worker dev",
    "dev:web": "pnpm --filter @karton/web dev",
    "typecheck": "pnpm -r typecheck"
  },
  "packageManager": "pnpm@11.10.0"
}
